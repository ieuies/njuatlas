# Copy this file to .env for local development.
# Do not commit real secrets.

GAODE_API_KEY=your-gaode-api-key
ZHIPU_API_KEY=
BAILIAN_API_KEY=your-bailian-api-key
# auto / bailian / zhipu (default auto; auto prefers Bailian first)
LLM_PROVIDER=bailian

# Generate with:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=replace-with-a-random-secret-at-least-32-chars
JWT_EXPIRATION_SECONDS=604800

# Optional for local development. If omitted, the app uses backend/foodmap.db.
# Render PostgreSQL provides this value from the dashboard.
DATABASE_URL=
FLASK_APP=app:create_app

# AMap search cache. Set TTL to 0 to disable cache.
AMAP_CACHE_TTL_SECONDS=300
AMAP_CACHE_MAX_ITEMS=256
AMAP_REQUEST_TIMEOUT_SECONDS=8
LOG_LEVEL=INFO
CONVERSATION_HISTORY_LIMIT=20
RATELIMIT_DEFAULT=200 per hour
RATELIMIT_STORAGE_URI=memory://

# 私信 SSE 实时推送（生产 Render 由 Blueprint 自动注入；本地可选）
REDIS_URL=

# Email and account recovery. Without RESEND_API_KEY, email contents are written to logs.
FRONTEND_URL=http://localhost:8080
EMAIL_VERIFICATION_TOKEN_SECONDS=86400
PASSWORD_RESET_TOKEN_SECONDS=1800
EMAIL_CODE_EXPIRATION_SECONDS=600
EMAIL_CODE_RESEND_SECONDS=60
EMAIL_CODE_MAX_ATTEMPTS=5
RESEND_API_KEY=
MAIL_FROM=今天奶龙吃什么 <no-reply@send.njuatlas.cn>

# Registration email suffix restriction (comma-separated; default enabled for NJU)
REGISTER_EMAIL_RESTRICTION_ENABLED=true
REGISTER_EMAIL_SUFFIX=@smail.nju.edu.cn,@nju.edu.cn
