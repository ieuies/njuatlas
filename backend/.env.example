# Copy this file to .env for local development.
# Do not commit real secrets.

GAODE_API_KEY=your-gaode-api-key
ZHIPU_API_KEY=your-zhipu-api-key
BAILIAN_API_KEY=

# Generate with:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=replace-with-a-random-secret-at-least-32-chars
JWT_EXPIRATION_SECONDS=86400

# Optional for local development. If omitted, the app uses backend/foodmap.db.
# Render PostgreSQL provides this value from the dashboard.
DATABASE_URL=
FLASK_APP=app:create_app

# AMap search cache. Set TTL to 0 to disable cache.
AMAP_CACHE_TTL_SECONDS=300
AMAP_CACHE_MAX_ITEMS=256
AMAP_REQUEST_TIMEOUT_SECONDS=8
LOG_LEVEL=INFO
CONVERSATION_HISTORY_LIMIT=20
RATELIMIT_DEFAULT=200 per hour
RATELIMIT_STORAGE_URI=memory://

# Email and account recovery. Without SMTP_HOST, email contents are written to logs.
FRONTEND_URL=http://localhost:5173
EMAIL_VERIFICATION_TOKEN_SECONDS=86400
PASSWORD_RESET_TOKEN_SECONDS=1800
EMAIL_CODE_EXPIRATION_SECONDS=600
EMAIL_CODE_RESEND_SECONDS=60
EMAIL_CODE_HOURLY_LIMIT=5
EMAIL_CODE_MAX_ATTEMPTS=5
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
MAIL_FROM=no-reply@njuatlas.local
