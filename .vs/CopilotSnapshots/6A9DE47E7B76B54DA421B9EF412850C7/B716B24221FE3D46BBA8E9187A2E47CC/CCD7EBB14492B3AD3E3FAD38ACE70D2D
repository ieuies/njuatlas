/* =====================================================================
   南大图谱 · 校园美食地图 — 现代优化设计版本
   主色: #7C3AED (渐变紫) 辅色: #EC4899 (玫瑰粉)
   ===================================================================== */

/* ========== CSS 变量 ========== */
:root {
    /* 品牌色系 - 现代渐变设计 */
    --primary: #7C3AED;
    --primary-dark: #6D28D9;
    --primary-light: #A78BFA;
    --accent: #EC4899;
    --accent-light: #F472B6;

    /* 背景色系 */
    --bg-primary: #ffffff;
    --bg-secondary: #F8FAFC;
    --bg-tertiary: #F1F5F9;

    /* 文本色系 */
    --text-primary: #1E293B;
    --text-secondary: #64748B;
    --text-tertiary: #94A3B8;

    /* 中性色 */
    --gray-50: #F9FAFB;
    --gray-100: #F3F4F6;
    --gray-200: #E5E7EB;
    --gray-300: #D1D5DB;
    --gray-400: #9CA3AF;
    --gray-500: #6B7280;
    --gray-600: #4B5563;
    --gray-700: #374151;
    --gray-800: #1F2937;
    --gray-900: #111827;

    /* 功能色 */
    --success: #10B981;
    --warning: #F59E0B;
    --danger: #EF4444;
    --info: #3B82F6;

    /* 布局尺寸 */
    --side-width: 240px;
    --msg-width: 300px;
    --topbar-height: 60px;

    /* 阴影系统 */
    --shadow-xs: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
    --shadow-sm: 0 1px 3px 0 rgba(0, 0, 0, 0.1), 0 1px 2px 0 rgba(0, 0, 0, 0.06);
    --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
    --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
    --shadow-xl: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);

    /* 过渡效果 */
    --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    --transition-fast: all 0.15s cubic-bezier(0.4, 0, 0.2, 1);
}

/* ========== 全局重置 ========== */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

html, body {
    height: 100%;
    width: 100%;
}

body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Microsoft YaHei', Roboto, sans-serif;
    background: var(--bg-secondary);
    color: var(--text-primary);
    min-height: 100vh;
    overflow-x: hidden;
}

/* 通用排版 */
h1, h2, h3, h4, h5, h6 {
    color: var(--text-primary);
    font-weight: 700;
    line-height: 1.3;
}

h4 {
    font-size: 1rem;
    margin: 1.2rem 0 0.8rem;
    color: var(--text-primary);
    font-weight: 600;
}

p {
    line-height: 1.6;
    color: var(--text-secondary);
}

a {
    color: var(--primary);
    text-decoration: none;
    transition: var(--transition-fast);
}

a:hover {
    color: var(--accent);
    text-decoration: underline;
}

/* =====================================================================
   三栏布局
   ===================================================================== */
.app-layout {
    display: flex;
    min-height: 100vh;
    width: 100%;
}

/* ========== 左侧栏 ========== */
.sidebar {
    width: var(--side-width);
    min-width: var(--side-width);
    background: linear-gradient(135deg, var(--primary-dark) 0%, var(--primary) 50%, var(--accent) 100%);
    color: white;
    display: flex;
    flex-direction: column;
    position: sticky;
    top: 0;
    height: 100vh;
    z-index: 200;
    box-shadow: var(--shadow-lg);
    overflow-y: auto;
}

.sidebar-header {
    padding: 1.5rem 1.3rem 1.2rem;
    border-bottom: 1px solid rgba(255,255,255,0.15);
}

.site-logo {
    display: flex;
    align-items: center;
    gap: 12px;
}

.logo-img {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: rgba(255,255,255,0.2);
    display: flex;
    align-items: center;
    justify-content: center;
}

.logo-text {
    font-size: 1.35rem;
    font-weight: 800;
    letter-spacing: 0.5px;
    background: linear-gradient(135deg, #fff, rgba(255, 255, 255, 0.8));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
}

.sidebar-nav {
    flex: 1;
    padding: 1rem 0.8rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
}

.nav-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 0.85rem 1.2rem;
    color: rgba(255,255,255,0.75);
    text-decoration: none;
    border-radius: 12px;
    font-size: 0.95rem;
    font-weight: 500;
    transition: var(--transition);
    position: relative;
}

.nav-item i {
    width: 20px;
    text-align: center;
    font-size: 1.15rem;
    transition: var(--transition);
}

.nav-item:hover {
    background: rgba(255,255,255,0.15);
    color: white;
    transform: translateX(4px);
}

.nav-item.active {
    background: rgba(255,255,255,0.25);
    color: white;
    font-weight: 600;
    box-shadow: inset 0 0 0 1px rgba(255,255,255,0.2);
}

.nav-item.active::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 4px;
    height: 24px;
    background: white;
    border-radius: 0 2px 2px 0;
}

.sidebar-footer {
    padding: 1.2rem;
    border-top: 1px solid rgba(255,255,255,0.15);
}

.sidebar-version {
    font-size: 0.75rem;
    opacity: 0.5;
    text-align: center;
    font-weight: 500;
}

/* ========== 主内容区 ========== */
.main-content {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    background: var(--bg-secondary);
}

/* ========== 顶栏 ========== */
.top-bar {
    height: var(--topbar-height);
    border-bottom: var(--shadow-sm);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 2rem;
    position: sticky;
    top: 0;
    z-index: 100;
    backdrop-filter: blur(12px);
    background: rgba(255, 255, 255, 0.98);
}

.top-bar-left {
    display: flex;
    align-items: center;
    gap: 20px;
}

.menu-toggle {
    display: none;
    background: none;
    border: none;
    font-size: 1.4rem;
    color: var(--primary);
    cursor: pointer;
    padding: 6px 8px;
    border-radius: 10px;
    transition: var(--transition-fast);
}

.menu-toggle:hover {
    background: var(--bg-tertiary);
    color: var(--accent);
}

.page-title {
    font-weight: 700;
    font-size: 1.3rem;
    color: var(--text-primary);
    display: flex;
    align-items: center;
    gap: 8px;
}

.page-title i {
    color: var(--primary);
}

/* 未登录时顶栏标题 */
body:not(.logged-in) .top-bar .page-title {
    background: linear-gradient(135deg, var(--primary), var(--accent));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
}

.top-bar-right {
    display: flex;
    align-items: center;
    gap: 12px;
}

/* 圆形登录按钮 */
.login-round-btn {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--primary), var(--accent));
    color: white;
    border: none;
    font-size: 0.85rem;
    font-weight: 700;
    cursor: pointer;
    transition: var(--transition);
    box-shadow: var(--shadow-md);
    letter-spacing: 0.5px;
    display: flex;
    align-items: center;
    justify-content: center;
}

.login-round-btn:hover {
    transform: translateY(-3px) scale(1.05);
    box-shadow: var(--shadow-xl);
}

.topbar-user {
    display: flex;
    align-items: center;
    gap: 8px;
    background: linear-gradient(135deg, rgba(124, 58, 237, 0.05), rgba(236, 72, 153, 0.05));
    padding: 0.5rem 0.5rem 0.5rem 1.2rem;
    border-radius: 50px;
    border: 1px solid var(--gray-200);
}

.topbar-username {
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--primary);
    max-width: 150px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}

.logout-btn {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: none;
    background: var(--bg-tertiary);
    color: var(--text-secondary);
    cursor: pointer;
    transition: var(--transition-fast);
    font-size: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
}

.logout-btn:hover {
    background: var(--danger);
    color: white;
    transform: scale(1.1);
}

/* ========== 内容区域 ========== */
.content-area {
    flex: 1;
    padding: 1.5rem;
    overflow-y: auto;
}

.page {
    display: none;
    will-change: transform, opacity;
    animation: fadeSlideUp 0.3s cubic-bezier(0.2, 0.9, 0.4, 1.1) forwards;
}

.page.active-page {
    display: block;
}

/* 页面切换平滑过渡（淡入 + 轻微上滑） */
@keyframes fadeSlideUp {
    from {
        opacity: 0;
        transform: translateY(12px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

/* ========== 未登录主页 — 简介区 ========== */
.hero-wrapper {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: calc(100vh - var(--topbar-height) - 80px);
    padding: 2rem 0;
}

.hero-content {
    text-align: center;
    max-width: 900px;
    width: 100%;
    padding: 0 1rem;
}

.hero-badge {
    display: inline-block;
    background: linear-gradient(135deg, rgba(124, 58, 237, 0.08), rgba(236, 72, 153, 0.08));
    color: var(--primary);
    padding: 0.5rem 1.5rem;
    border-radius: 50px;
    font-size: 0.9rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
    border: 1px solid rgba(124, 58, 237, 0.2);
    letter-spacing: 0.5px;
}

.hero-title {
    font-size: 3.8rem;
    font-weight: 800;
    background: linear-gradient(135deg, var(--primary), var(--accent));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    margin-bottom: 0.8rem;
    line-height: 1.2;
    letter-spacing: -0.5px;
}

.hero-subtitle {
    font-size: 1.2rem;
    color: var(--text-secondary);
    max-width: 550px;
    margin: 0 auto 2.5rem;
    line-height: 1.8;
    font-weight: 500;
}

.hero-actions {
    margin-bottom: 3rem;
}

.hero-btn {
    background: linear-gradient(135deg, var(--primary), var(--accent));
    color: white;
    border: none;
    padding: 0.95rem 2.8rem;
    border-radius: 60px;
    font-size: 1.1rem;
    font-weight: 700;
    cursor: pointer;
    transition: var(--transition);
    box-shadow: var(--shadow-lg);
}

.hero-btn:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-xl);
}

.feature-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.8rem;
    margin-top: 1.5rem;
}

.feature-card {
    background: var(--bg-primary);
    border-radius: 16px;
    padding: 2rem 1.8rem;
    border: 1px solid var(--gray-200);
    transition: var(--transition);
    box-shadow: var(--shadow-sm);
}

.feature-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    border-color: var(--primary-light);
}

.feature-card i {
    font-size: 2.4rem;
    background: linear-gradient(135deg, var(--primary), var(--accent));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    margin-bottom: 1rem;
}

.feature-card h3 {
    font-size: 1.15rem;
    margin-bottom: 0.5rem;
    color: var(--text-primary);
    font-weight: 600;
}

.feature-card p {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.6;
}

/* ========== 页面通用 ========== */
.page-header-flex {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
}

.page-header-flex h2 {
    font-size: 1.4rem;
    color: var(--text-primary);
    font-weight: 700;
}

.page-placeholder {
    text-align: center;
    padding: 6rem 2rem;
    color: var(--text-secondary);
}

.page-placeholder h2 {
    margin: 1.5rem 0 0.8rem;
    color: var(--primary);
    font-size: 1.4rem;
}

/* ========== 餐厅卡片 ========== */
.resto-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(290px, 1fr));
    gap: 1.8rem;
    margin-top: 1.2rem;
}

.resto-card {
    background: var(--bg-primary);
    border-radius: 16px;
    overflow: hidden;
    cursor: pointer;
    transition: var(--transition);
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--gray-200);
}

.resto-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    border-color: var(--primary-light);
}

.resto-img {
    height: 180px;
    background-size: cover;
    background-position: center;
    background-color: var(--gray-300);
}

.resto-info {
    padding: 1.2rem;
}

.resto-name {
    font-weight: 700;
    font-size: 1.15rem;
    margin-bottom: 0.3rem;
    color: var(--text-primary);
}

/* ========== 地图 ========== */
#mapContainer {
    width: 100%;
    height: 540px;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: var(--shadow-md);
    margin: 1.2rem 0;
    background: var(--gray-300);
    border: 1px solid var(--gray-200);
}

.map-loading,
.list-empty {
    min-height: 200px;
    display: grid;
    place-items: center;
    color: var(--text-tertiary);
    background: var(--bg-tertiary);
    border-radius: 16px;
}

/* ========== AI 聊天 ========== */
.ai-hint {
    color: var(--text-secondary);
    margin-bottom: 1rem;
    font-size: 0.95rem;
}

.chat-area {
    background: var(--bg-primary);
    border-radius: 16px;
    padding: 1.5rem;
    height: 420px;
    overflow-y: auto;
    border: 1px solid var(--gray-200);
    box-shadow: var(--shadow-sm);
}

.chat-message {
    margin: 0.8rem 0;
    padding: 0.8rem 1.2rem;
    border-radius: 16px;
    max-width: 85%;
    word-wrap: break-word;
    line-height: 1.6;
    font-size: 0.95rem;
}

.chat-user {
    background: linear-gradient(135deg, var(--primary), var(--primary-light));
    margin-left: auto;
    text-align: right;
    border-bottom-right-radius: 4px;
    color: white;
}

.chat-bot {
    background: var(--bg-tertiary);
    border-bottom-left-radius: 4px;
    border: 1px solid var(--gray-200);
    color: var(--text-primary);
}

.chat-input-area {
    display: flex;
    gap: 1rem;
    margin-top: 1rem;
}

.chat-input-area input {
    flex: 1;
    padding: 0.8rem 1.2rem;
    border-radius: 60px;
    border: 1px solid var(--gray-300);
    background: var(--bg-primary);
    font-size: 0.95rem;
    transition: var(--transition-fast);
    color: var(--text-primary);
}

.chat-input-area input::placeholder {
    color: var(--text-tertiary);
}

.chat-input-area input:focus {
    outline: none;
    border-color: var(--primary);
    box-shadow: 0 0 0 3px rgba(124, 58, 237, 0.1);
}

/* ========== 右侧消息栏 ========== */
.message-panel {
    width: var(--msg-width);
    min-width: var(--msg-width);
    background: var(--bg-primary);
    border-left: var(--shadow-xs);
    display: flex;
    flex-direction: column;
    height: 100vh;
    position: sticky;
    top: 0;
}

.message-panel-header {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 1.2rem;
    font-weight: 700;
    font-size: 1rem;
    color: var(--text-primary);
    border-bottom: var(--shadow-xs);
}

.message-panel-body {
    flex: 1;
    overflow-y: auto;
    padding: 1.2rem 0.8rem;
}

.message-empty {
    text-align: center;
    padding: 2.5rem 1rem;
    color: var(--text-tertiary);
}

.message-empty i {
    font-size: 2.5rem;
    margin-bottom: 0.8rem;
    color: var(--gray-300);
}

.message-empty p {
    font-size: 0.9rem;
}

.message-item {
    display: flex;
    gap: 10px;
    padding: 0.9rem;
    border-radius: 12px;
    transition: var(--transition-fast);
    cursor: pointer;
}

.message-item:hover {
    background: var(--bg-tertiary);
}

.message-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent);
    margin-top: 6px;
    flex-shrink: 0;
}

.message-content {
    flex: 1;
    min-width: 0;
}

.message-title {
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--text-primary);
}

.message-time {
    font-size: 0.75rem;
    color: var(--text-tertiary);
    margin-top: 3px;
}

/* ========== 底栏 ========== */
.site-footer {
    border-top: var(--shadow-xs);
    background: var(--bg-primary);
    padding: 1.2rem 1.5rem;
    margin-top: auto;
}

.footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.8rem;
    max-width: 1200px;
    margin: 0 auto;
}

.footer-brand {
    display: flex;
    align-items: center;
    gap: 12px;
}

.footer-logo {
    font-weight: 700;
    color: var(--primary);
    font-size: 1rem;
}

.footer-desc {
    font-size: 0.8rem;
    color: var(--text-secondary);
}

.footer-copyright {
    font-size: 0.8rem;
    color: var(--text-tertiary);
    text-align: right;
}

/* ========== 模态框 ========== */
.modal {
    display: none;
    position: fixed;
    top:0; left:0;
    width:100%; height:100%;
    background: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(8px);
    justify-content: center;
    align-items: center;
    z-index: 1000;
}

.modal-card {
    background: var(--bg-primary);
    border-radius: 20px;
    width: 90%;
    max-width: 480px;
    padding: 2.2rem 2rem;
    box-shadow: var(--shadow-xl);
    position: relative;
    animation: modalPop 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes modalPop {
    from { opacity: 0; transform: scale(0.92) translateY(10px); }
    to   { opacity: 1; transform: scale(1) translateY(0); }
}

.modal-close-btn {
    position: absolute;
    top: 14px;
    right: 14px;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: none;
    background: var(--bg-tertiary);
    color: var(--text-secondary);
    cursor: pointer;
    transition: var(--transition-fast);
    font-size: 0.95rem;
    display: flex;
    align-items: center;
    justify-content: center;
}

.modal-close-btn:hover {
    background: var(--danger);
    color: white;
}

.modal-card h2 {
    margin-bottom: 1.5rem;
    color: var(--text-primary);
    font-size: 1.5rem;
    font-weight: 700;
}

.modal-card input, .modal-card textarea, .modal-card select {
    width: 100%;
    margin-bottom: 1rem;
    padding: 0.9rem 1.1rem;
    border-radius: 12px;
    border: 1px solid var(--gray-300);
    background: var(--bg-secondary);
    transition: var(--transition-fast);
    font-size: 0.95rem;
    color: var(--text-primary);
}

.modal-card input::placeholder, .modal-card textarea::placeholder {
    color: var(--text-tertiary);
}

.modal-card input:focus {
    border-color: var(--primary);
    outline: none;
    box-shadow: 0 0 0 3px rgba(124, 58, 237, 0.1);
    background: var(--bg-primary);
}

.modal-card textarea:focus {
    border-color: var(--primary);
    outline: none;
    box-shadow: 0 0 0 3px rgba(124, 58, 237, 0.1);
    background: var(--bg-primary);
}

.modal-actions {
    display: flex;
    gap: 1rem;
    margin: 1.5rem 0 0;
}

.switch-mode {
    text-align: center;
    margin-top: 1rem;
    font-size: 0.9rem;
    color: var(--text-secondary);
}

.switch-mode a {
    color: var(--primary);
    cursor: pointer;
    font-weight: 600;
    text-decoration: none;
}

.switch-mode a:hover {
    text-decoration: underline;
}

.flex-between {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.2rem;
}

.flex-between h3 {
    font-size: 1.15rem;
    color: var(--text-primary);
    font-weight: 700;
    margin: 0;
}

.close-btn {
    background: var(--bg-tertiary);
    border: none;
    font-size: 1.15rem;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    cursor: pointer;
    transition: var(--transition-fast);
    color: var(--text-secondary);
    display: flex;
    align-items: center;
    justify-content: center;
}

.close-btn:hover {
    background: var(--danger);
    color: white;
}

/* ========== 按钮 ========== */
.primary-btn, .secondary-btn, .small-btn {
    border: none;
    padding: 0.7rem 1.6rem;
    border-radius: 60px;
    font-weight: 600;
    cursor: pointer;
    transition: var(--transition-fast);
    font-size: 0.9rem;
    display: inline-flex;
    align-items: center;
    gap: 8px;
}

.primary-btn {
    background: linear-gradient(135deg, var(--primary), var(--accent));
    color: white;
    box-shadow: var(--shadow-md);
}

.primary-btn:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
}

.secondary-btn {
    background: var(--bg-tertiary);
    color: var(--text-primary);
    border: 1px solid var(--gray-300);
}

.secondary-btn:hover {
    background: var(--gray-200);
    border-color: var(--primary);
}

.small-btn {
    background: var(--bg-tertiary);
    color: var(--text-primary);
    padding: 0.35rem 1.1rem;
    font-size: 0.85rem;
    border: 1px solid var(--gray-300);
}

.small-btn:hover {
    background: var(--gray-300);
    border-color: var(--primary);
}

/* ========== 个人中心 ========== */
.profile-shell {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
}

.profile-card {
    background: var(--bg-primary);
    border-radius: 16px;
    padding: 1.8rem;
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--gray-200);
}

.profile-summary {
    display: flex;
    align-items: center;
    gap: 1.5rem;
}

.profile-avatar {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    background: linear-gradient(135deg, var(--primary), var(--accent));
    color: white;
    font-size: 1.8rem;
    flex: 0 0 auto;
    box-shadow: var(--shadow-md);
}

.profile-main {
    min-width: 0;
}

.profile-main h2 {
    margin: 0 0 0.3rem;
    color: var(--text-primary);
    font-size: 1.4rem;
    font-weight: 700;
}

.profile-main p {
    margin: 0;
    color: var(--text-secondary);
    word-break: break-word;
    font-size: 0.95rem;
}

.profile-status-row {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 0.75rem;
}

.profile-status {
    display: inline-flex;
    align-items: center;
    min-height: 28px;
    padding: 0.3rem 0.9rem;
    border-radius: 999px;
    font-size: 0.85rem;
    font-weight: 600;
}

.profile-status.is-verified {
    background: rgba(16, 185, 129, 0.1);
    color: #065f46;
}

.profile-status.is-unverified {
    background: rgba(239, 68, 68, 0.1);
    color: #7f1d1d;
}

.profile-stats {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
}

.profile-stat {
    min-height: 80px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 1.2rem;
    background: linear-gradient(135deg, rgba(124, 58, 237, 0.05), rgba(236, 72, 153, 0.05));
    border: 1px solid var(--gray-200);
    border-radius: 12px;
    box-shadow: var(--shadow-xs);
}

.profile-stat span {
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--primary);
}

.profile-stat small {
    color: var(--text-secondary);
    margin-top: 0.35rem;
    font-size: 0.85rem;
}

.profile-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.5rem;
}

.profile-section-title {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 1.2rem;
    color: var(--text-primary);
}

.profile-section-title i {
    color: var(--primary);
    font-size: 1.1rem;
}

.profile-section-title h3 {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 700;
}

.profile-list {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
}

.profile-list-item {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem;
    border: 1px solid var(--gray-200);
    border-radius: 12px;
    background: var(--bg-tertiary);
    transition: var(--transition-fast);
}

.profile-list-item:hover {
    border-color: var(--primary-light);
    background: var(--bg-secondary);
}

.profile-list-item strong {
    display: block;
    color: var(--text-primary);
    margin-bottom: 0.3rem;
    font-weight: 600;
}

.profile-list-item p {
    margin: 0;
    color: var(--text-secondary);
    line-height: 1.5;
    font-size: 0.9rem;
}

.profile-list-item time {
    flex: 0 0 auto;
    color: var(--text-tertiary);
    font-size: 0.8rem;
    white-space: nowrap;
}

.profile-empty {
    padding: 1.5rem;
    border: 1px dashed var(--gray-300);
    border-radius: 12px;
    color: var(--text-tertiary);
    background: var(--bg-tertiary);
    text-align: center;
}

.profile-tag {
    display: inline-flex;
    margin-top: 0.5rem;
    padding: 0.3rem 0.8rem;
    border-radius: 999px;
    background: linear-gradient(135deg, rgba(124, 58, 237, 0.1), rgba(236, 72, 153, 0.1));
    color: var(--primary);
    font-size: 0.8rem;
    font-weight: 500;
}

.profile-muted {
    color: var(--text-tertiary);
}

.password-form {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr) auto;
    gap: 0.8rem;
}

.password-form input {
    width: 100%;
    min-height: 44px;
    border-radius: 12px;
    border: 1px solid var(--gray-300);
    padding: 0 1rem;
    background: var(--bg-secondary);
    color: var(--text-primary);
    transition: var(--transition-fast);
    font-size: 0.95rem;
}

.password-form input::placeholder {
    color: var(--text-tertiary);
}

.password-form input:focus {
    outline: none;
    border-color: var(--primary);
    background: var(--bg-primary);
    box-shadow: 0 0 0 3px rgba(124, 58, 237, 0.1);
}

/* ========== Toast 提示 ========== */
.toast {
    position: fixed;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%);
    background: linear-gradient(135deg, var(--primary), var(--accent));
    backdrop-filter: blur(10px);
    color: white;
    padding: 12px 28px;
    border-radius: 60px;
    z-index: 2000;
    font-size: 0.9rem;
    font-weight: 500;
    letter-spacing: 0.3px;
    pointer-events: none;
    box-shadow: var(--shadow-lg);
}

/* =====================================================================
   响应式 — 小屏幕
   ===================================================================== */
@media (max-width: 1100px) {
    .message-panel {
        display: none;
    }
}

@media (max-width: 768px) {
    .sidebar {
        position: fixed;
        left: -280px;
        transition: left 0.3s ease;
        z-index: 300;
        box-shadow: 4px 0 30px rgba(0,0,0,0.3);
    }

    .sidebar.open {
        left: 0;
    }

    .menu-toggle {
        display: block;
    }

    .sidebar-overlay {
        display: none;
        position: fixed;
        top: 0; left: 0; right: 0; bottom: 0;
        background: rgba(0,0,0,0.4);
        z-index: 299;
    }

    .sidebar-overlay.show {
        display: block;
    }

    .content-area {
        padding: 1rem;
    }

    .profile-summary {
        align-items: flex-start;
    }

    .profile-stats,
    .profile-grid {
        grid-template-columns: 1fr;
    }

    .profile-list-item {
        flex-direction: column;
    }

    .profile-list-item time {
        white-space: normal;
    }

    .password-form {
        grid-template-columns: 1fr;
    }

    .hero-title {
        font-size: 2.2rem;
    }

    .footer-inner {
        flex-direction: column;
        text-align: center;
    }

    .footer-copyright {
        text-align: center;
    }
}

/* ========== 快捷提问按钮 ========== */
.quick-questions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    margin: 1rem 0;
}

.quick-q-btn {
    background: var(--bg-primary);
    border: 1px solid var(--gray-300);
    padding: 0.6rem 1.4rem;
    border-radius: 60px;
    font-size: 0.9rem;
    color: var(--primary);
    cursor: pointer;
    transition: var(--transition-fast);
    font-weight: 500;
    white-space: nowrap;
    box-shadow: var(--shadow-xs);
}

.quick-q-btn:hover {
    background: linear-gradient(135deg, rgba(124, 58, 237, 0.05), rgba(236, 72, 153, 0.05));
    border-color: var(--primary-light);
    transform: translateY(-2px);
}

.code-row {
    display: flex;
    gap: 10px;
    align-items: center;
}

.code-row input {
    flex: 1;
    min-width: 0;
}

.code-row button {
    white-space: nowrap;
}

.topbar-username {
    cursor: pointer;
    transition: opacity 0.2s;
}

.topbar-username:hover {
    opacity: 0.8;
    text-decoration: underline;
}

.partner-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 1.5rem;
    margin-bottom: 2rem;
}

.partner-header-left h2 {
    font-size: 1.5rem;
    color: var(--text-primary);
    margin-bottom: 0.4rem;
    font-weight: 700;
}

.partner-subtitle {
    color: var(--text-secondary);
    font-size: 0.95rem;
}

.partner-filter {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    margin-bottom: 2rem;
}

.filter-chip {
    background: var(--bg-primary);
    border: 1px solid var(--gray-300);
    padding: 0.6rem 1.4rem;
    border-radius: 60px;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-primary);
    cursor: pointer;
    transition: var(--transition-fast);
    box-shadow: var(--shadow-xs);
}

.filter-chip:hover {
    background: linear-gradient(135deg, rgba(124, 58, 237, 0.05), rgba(236, 72, 153, 0.05));
    border-color: var(--primary-light);
    transform: translateY(-2px);
}

.filter-chip.active {
    background: linear-gradient(135deg, var(--primary), var(--accent));
    color: white;
    border-color: transparent;
    box-shadow: var(--shadow-md);
}

.partner-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.8rem;
}

.partner-card {
    background: var(--bg-primary);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--gray-200);
    transition: var(--transition);
    display: flex;
    flex-direction: column;
}

.partner-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    border-color: var(--primary-light);
}

.partner-card-content {
    padding: 1.4rem;
    flex: 1;
}

.partner-card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1rem;
    gap: 0.5rem;
}

.partner-category {
    background: linear-gradient(135deg, rgba(124, 58, 237, 0.1), rgba(236, 72, 153, 0.1));
    color: var(--primary);
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.35rem 0.9rem;
    border-radius: 30px;
    letter-spacing: 0.5px;
    flex-shrink: 0;
}

.partner-time {
    font-size: 0.75rem;
    color: var(--text-tertiary);
}

.partner-card-title {
    font-size: 1.15rem;
    font-weight: 700;
    margin: 0.5rem 0 0.5rem;
    color: var(--text-primary);
}

.partner-card-desc {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.5;
    margin-bottom: 0.8rem;
    white-space: pre-wrap;
}

.partner-card-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid var(--gray-200);
    padding-top: 1rem;
    margin-top: auto;
}

.partner-publisher {
    font-size: 0.8rem;
    color: var(--text-secondary);
    display: flex;
    align-items: center;
    gap: 6px;
}

.contact-btn {
    background: transparent;
    border: 1px solid var(--primary-light);
    color: var(--primary);
    padding: 0.35rem 1rem;
    border-radius: 60px;
    font-size: 0.8rem;
    font-weight: 600;
    cursor: pointer;
    transition: var(--transition-fast);
}

.contact-btn:hover {
    background: linear-gradient(135deg, var(--primary), var(--accent));
    color: white;
    border-color: transparent;
}

/* 发布模态框内的下拉框样式 */
#partnerModal select {
    width: 100%;
    margin-bottom: 1rem;
    padding: 0.9rem 1.1rem;
    border-radius: 12px;
    border: 1px solid var(--gray-300);
    background: var(--bg-secondary);
    font-size: 0.95rem;
    color: var(--text-primary);
    transition: var(--transition-fast);
}

#partnerModal select:focus {
    outline: none;
    border-color: var(--primary);
    background: var(--bg-primary);
    box-shadow: 0 0 0 3px rgba(124, 58, 237, 0.1);
}
    font-family: inherit;
}

#partnerModal select:focus {
    border-color: var(--njupurple);
    outline: none;
    box-shadow: 0 0 0 3px rgba(75, 0, 130, 0.1);
}

/* ========== 新增特效：按钮点击缩放 ========== */
button,
.primary-btn,
.secondary-btn,
.small-btn,
.nav-item,
.join-btn,
.contact-btn,
.filter-chip,
.quick-q-btn,
.hero-btn,
.login-round-btn,
.logout-btn,
.modal-close-btn,
.close-btn,
#refreshRestosBtn,
#sendChatBtn,
.resto-card,
.partner-card,
.feature-card,
.sidebar-nav .nav-item,
.message-item,
.hero-btn,
.code-row button,
#openPartnerModalBtn,
#submitPartnerBtn,
#cancelPartnerBtn,
#closePartnerModalBtn,
#likeRestoBtn,
#favRestoBtn,
#postReviewBtn,
#changePasswordBtn,
#sendVerifyEmailBtn,
#doLoginBtn,
#doRegisterBtn,
#doForgotBtn,
#sendRegCodeBtn,
#sendForgotCodeBtn,
#getStartedBtn,
#showLoginBtn,
.menu-toggle {
    transition: transform 0.12s cubic-bezier(0.2, 0.9, 0.4, 1.1), box-shadow 0.2s ease;
    will-change: transform;
}

button:active,
.primary-btn:active,
.secondary-btn:active,
.small-btn:active,
.nav-item:active,
.join-btn:active,
.contact-btn:active,
.filter-chip:active,
.quick-q-btn:active,
.hero-btn:active,
.login-round-btn:active,
.logout-btn:active,
.modal-close-btn:active,
.close-btn:active,
#refreshRestosBtn:active,
#sendChatBtn:active,
.code-row button:active,
#openPartnerModalBtn:active,
#submitPartnerBtn:active,
#cancelPartnerBtn:active,
#closePartnerModalBtn:active,
#likeRestoBtn:active,
#favRestoBtn:active,
#postReviewBtn:active,
#changePasswordBtn:active,
#sendVerifyEmailBtn:active,
#doLoginBtn:active,
#doRegisterBtn:active,
#doForgotBtn:active,
#sendRegCodeBtn:active,
#sendForgotCodeBtn:active,
#getStartedBtn:active,
#showLoginBtn:active,
.menu-toggle:active {
    transform: scale(0.96);
}

/* 卡片类点击反馈（略微缩小） */
.resto-card:active,
.partner-card:active,
.feature-card:active,
.message-item:active {
    transform: scale(0.98);
}
